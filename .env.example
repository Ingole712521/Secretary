# =============================================================================
# Jarvis OS — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in values for your environment.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_NAME=Jarvis OS
APP_ENV=development
# Options: development | staging | production
DEBUG=true
LOG_LEVEL=INFO
# Options: DEBUG | INFO | WARNING | ERROR

# API server
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/v1

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# Generate a secure random string for production
# Example: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_SECRET_KEY=change-me-in-production

# Comma-separated list of allowed origins (CORS)
# Example: http://localhost:3000,https://app.example.com
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# -----------------------------------------------------------------------------
# AI / LLM Providers (Phase 2+)
# -----------------------------------------------------------------------------
# LLM_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# -----------------------------------------------------------------------------
# Database (Phase 3+)
# -----------------------------------------------------------------------------
# DATABASE_URL=postgresql+asyncpg://jarvis:password@localhost:5432/jarvis
# DATABASE_POOL_SIZE=10

# -----------------------------------------------------------------------------
# Redis (Phase 3+)
# -----------------------------------------------------------------------------
# REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# Memory / Vector Store (Phase 3+)
# -----------------------------------------------------------------------------
# VECTOR_STORE_URL=
# EMBEDDING_MODEL=text-embedding-3-small

# -----------------------------------------------------------------------------
# GitHub Integration (Phase 9+)
# -----------------------------------------------------------------------------
# GITHUB_TOKEN=
# GITHUB_API_URL=https://api.github.com

# -----------------------------------------------------------------------------
# Docker (Phase 10+)
# -----------------------------------------------------------------------------
# DOCKER_HOST=unix:///var/run/docker.sock

# -----------------------------------------------------------------------------
# Kubernetes (Phase 11+)
# -----------------------------------------------------------------------------
# KUBECONFIG=/path/to/kubeconfig
# K8S_NAMESPACE=jarvis

# -----------------------------------------------------------------------------
# AWS (Phase 12+)
# -----------------------------------------------------------------------------
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_DEFAULT_OUTPUT=json

# -----------------------------------------------------------------------------
# Hostinger (Phase 13+)
# -----------------------------------------------------------------------------
# HOSTINGER_API_TOKEN=

# -----------------------------------------------------------------------------
# Voice (Phase 6+)
# -----------------------------------------------------------------------------
# STT_PROVIDER=whisper
# TTS_PROVIDER=
# OPENAI_WHISPER_MODEL=whisper-1

# -----------------------------------------------------------------------------
# Browser Automation (Phase 8+)
# -----------------------------------------------------------------------------
# BROWSER_HEADLESS=true
# BROWSER_ALLOWED_DOMAINS=localhost,127.0.0.1

# -----------------------------------------------------------------------------
# Email (Future)
# -----------------------------------------------------------------------------
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@example.com

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
# Correlation ID header name
CORRELATION_ID_HEADER=X-Correlation-ID

# Enable JSON structured logging in production
LOG_JSON=false
