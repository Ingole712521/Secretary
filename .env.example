# =============================================================================
# Jarvis OS — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in values for your environment.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_NAME=Jarvis OS
APP_ENV=development
# Options: development | staging | production
DEBUG=true
LOG_LEVEL=INFO
# Options: DEBUG | INFO | WARNING | ERROR

# API server
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/v1
APP_VERSION=0.1.0

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# Generate a secure random string for production
# Example: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_SECRET_KEY=change-me-in-production

# Comma-separated list of allowed origins (CORS)
# Example: http://localhost:3000,https://app.example.com
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# -----------------------------------------------------------------------------
# AI / LLM Providers (Sprint 2+ config — adapters wired in Sprint 3)
# -----------------------------------------------------------------------------
# Active provider: openai | openrouter | anthropic | gemini | deepseek | ollama | lm_studio
LLM_PROVIDER=openrouter

# OpenAI (direct API)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o
# OPENAI_API_BASE=

# OpenRouter (recommended if your key starts with sk-or-v1-)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/auto
OPENROUTER_API_BASE=https://openrouter.ai/api/v1

# Jarvis personality for multi-turn chat (Sprint 4+)
# JARVIS_SYSTEM_PROMPT=You are Jarvis, a personal AI assistant...

# Tool platform (Sprint 5+)
TOOLS_ENABLED=true
DESKTOP_AUTOMATION_ENABLED=true
TERMINAL_COMMAND_TIMEOUT=30
CHAT_MAX_TOOL_ITERATIONS=5
# Directories to search when opening a project in Cursor by name.
# Comma or semicolon separated. Leave empty to auto-detect common
# code folders under your home directory and fixed drives.
CURSOR_PROJECT_ROOTS=
CURSOR_PROJECT_SEARCH_DEPTH=3

# Long-term memory (Sprint 7+)
MEMORY_ENABLED=true
# MEMORY_DB_PATH=data/memory.db
MEMORY_SEARCH_LIMIT=10
MEMORY_CONTEXT_LIMIT=5

# Legacy: OpenRouter keys stored under OPENAI_API_KEY still work when
# LLM_PROVIDER=openrouter and the key starts with sk-or-v1-

# Anthropic
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Google Gemini
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# DeepSeek
# DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-chat

# Local providers (no API key required)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3
# LM_STUDIO_BASE_URL=http://localhost:1234/v1
# LM_STUDIO_MODEL=local-model

# -----------------------------------------------------------------------------
# Database (Phase 3+)
# -----------------------------------------------------------------------------
# DATABASE_URL=postgresql+asyncpg://jarvis:password@localhost:5432/jarvis
# DATABASE_POOL_SIZE=10

# -----------------------------------------------------------------------------
# Redis (Phase 3+)
# -----------------------------------------------------------------------------
# REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# Memory / Vector Store (Phase 3+)
# -----------------------------------------------------------------------------
# VECTOR_STORE_URL=
# EMBEDDING_MODEL=text-embedding-3-small

# -----------------------------------------------------------------------------
# GitHub Integration (Phase 9+)
# -----------------------------------------------------------------------------
# GITHUB_TOKEN=
# GITHUB_API_URL=https://api.github.com

# -----------------------------------------------------------------------------
# Docker (Phase 10+)
# -----------------------------------------------------------------------------
# DOCKER_HOST=unix:///var/run/docker.sock

# -----------------------------------------------------------------------------
# Kubernetes (Phase 11+)
# -----------------------------------------------------------------------------
# KUBECONFIG=/path/to/kubeconfig
# K8S_NAMESPACE=jarvis

# -----------------------------------------------------------------------------
# AWS (Phase 12+)
# -----------------------------------------------------------------------------
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_DEFAULT_OUTPUT=json

# -----------------------------------------------------------------------------
# Hostinger (Phase 13+)
# -----------------------------------------------------------------------------
# HOSTINGER_API_TOKEN=

# -----------------------------------------------------------------------------
# Voice Platform (Sprint 8+)
# -----------------------------------------------------------------------------
VOICE_ENABLED=true
VOICE_STT_PROVIDER=faster_whisper
VOICE_TTS_PROVIDER=piper
VOICE_VAD_PROVIDER=manual
VOICE_WAKEWORD_PROVIDER=openwakeword
VOICE_WAKE_WORD=hey jarvis
# VOICE_MICROPHONE_PROVIDER=sounddevice
# VOICE_AUDIO_OUTPUT_PROVIDER=sounddevice
# VOICE_SAMPLE_RATE=16000
# VOICE_SILENCE_TIMEOUT_MS=800
# VOICE_LANGUAGE=en
# VOICE_WHISPER_MODEL=base
# VOICE_WHISPER_DEVICE=cpu
# VOICE_WHISPER_COMPUTE_TYPE=int8
# VOICE_PIPER_VOICE=data/voices/en_US-lessac-medium.onnx
# OPENAI_WHISPER_MODEL=whisper-1
# OPENAI_TTS_MODEL=tts-1
# OPENAI_TTS_VOICE=alloy
# EDGE_TTS_VOICE=en-US-GuyNeural

# -----------------------------------------------------------------------------
# Browser Automation (Phase 8+)
# -----------------------------------------------------------------------------
# BROWSER_HEADLESS=true
# BROWSER_ALLOWED_DOMAINS=localhost,127.0.0.1

# -----------------------------------------------------------------------------
# Email (Future)
# -----------------------------------------------------------------------------
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@example.com

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
# Correlation ID header name
CORRELATION_ID_HEADER=X-Correlation-ID

# Enable JSON structured logging in production
LOG_JSON=false
LOG_DIR=logs
LOG_FILE_NAME=jarvis.log
LOG_FILE_MAX_BYTES=10485760
LOG_FILE_BACKUP_COUNT=5

# Data directory
DATA_DIR=data
